+/* Parse a color name (X11 named color or #rrggbb) into 8-bit RGB values
+ * without allocating a colormap entry. Returns 1 on success, 0 on
+ * failure (in which case r, g, and b are all set to 0). */
+int alock_parse_rgb(Display *display, const char *name,
+        uint8_t *r, uint8_t *g, uint8_t *b) {
+
+    *r = *g = *b = 0;
+
+    if (!display || !name)
+        return 0;
+
+    XColor c;
+    Colormap cmap = DefaultColormap(display, DefaultScreen(display));
+    if (XParseColor(display, cmap, name, &c) == 0)
+        return 0;
+
+    *r = c.red   >> 8;
+    *g = c.green >> 8;
+    *b = c.blue  >> 8;
+    return 1;
+}
+
+/* Composite ARGB pixel data against an opaque background color,
+ * producing fully-opaque pixels (alpha = 255) with the same visible
+ * appearance as the original pixels would have on that background.
+ *
+ * Pixel format: 0xAARRGGBB (alpha in bits 24-31, R in 16-23, G in 8-15,
+ * B in 0-7).  Set `premultiplied` to nonzero if the input RGB channels
+ * are already pre-multiplied by alpha (e.g. xcursor format); zero if
+ * the input is straight ARGB (e.g. imlib2 cursor data as currently
+ * used in alock).
+ *
+ * Eliminating non-255 alpha removes any save-under requirement when the
+ * cursor is composited by the X server, so stale framebuffer pixels
+ * cannot bleed through the cursor on resume from suspend. */
+void alock_flatten_argb(uint32_t *pixels, size_t count,
+        uint8_t bg_r, uint8_t bg_g, uint8_t bg_b,
+        int premultiplied) {
+
+    if (!pixels)
+        return;
+
+    for (size_t i = 0; i < count; i++) {
+        uint32_t px = pixels[i];
+        unsigned a = (px >> 24) & 0xff;
+        unsigned r = (px >> 16) & 0xff;
+        unsigned g = (px >>  8) & 0xff;
+        unsigned b = (px >>  0) & 0xff;
+        unsigned inv = 255 - a;
+
+        unsigned out_r, out_g, out_b;
+        if (premultiplied) {
+            out_r = r + (bg_r * inv + 127) / 255;
+            out_g = g + (bg_g * inv + 127) / 255;
+            out_b = b + (bg_b * inv + 127) / 255;
+        } else {
+            out_r = (r * a + bg_r * inv + 127) / 255;
+            out_g = (g * a + bg_g * inv + 127) / 255;
+            out_b = (b * a + bg_b * inv + 127) / 255;
+        }
+        if (out_r > 255) out_r = 255;
+        if (out_g > 255) out_g = 255;
+        if (out_b > 255) out_b = 255;
+
+        pixels[i] = (0xffu << 24) | (out_r << 16) | (out_g << 8) | out_b;
+    }
+}
