+/* On resume from suspend, hide the cursor via XFixes, reinitialize the cursor
+ * hardware plane via an XRandR same-mode modeset, then poll until the
+ * framebuffer is stable before showing the cursor again.
+ *
+ * Stability test: XGetImage without a compositor reads the actual hardware
+ * framebuffer.  If NVIDIA's async VRAM restore is still overwriting our
+ * XClearArea calls, consecutive samples will differ.  We loop (max 20 × 300 ms
+ * = 6 s) until two samples in a row agree, meaning the restore has finished
+ * and our clear has stuck. */
+static void refreshCursorAfterResume(Display *display, struct aModules *modules) {
+
+    int nscreens = ScreenCount(display);
+    Window bgwins[nscreens];
+    int bgcount = 0;
+
+    for (int i = 0; i < nscreens; i++)
+        XFixesHideCursor(display, RootWindow(display, i));
+
+    /* Reinit cursor hardware plane while cursor is hidden and framebuffer may
+     * still be stale — the driver has no cached sprite to reuse after this. */
+    for (int i = 0; i < nscreens; i++) {
+        Window root = RootWindow(display, i);
+        XRRScreenResources *rr = XRRGetScreenResourcesCurrent(display, root);
+        if (!rr) continue;
+        for (int c = 0; c < rr->ncrtc; c++) {
+            XRRCrtcInfo *ci = XRRGetCrtcInfo(display, rr, rr->crtcs[c]);
+            if (ci && ci->mode != None)
+                XRRSetCrtcConfig(display, rr, rr->crtcs[c], CurrentTime,
+                        ci->x, ci->y, ci->mode, ci->rotation,
+                        ci->outputs, ci->noutput);
+            if (ci) XRRFreeCrtcInfo(ci);
+        }
+        XRRFreeScreenResources(rr);
+    }
+    XSync(display, False);
+
+    for (int i = 0; i < nscreens; i++) {
+        Window bg = modules->background->getwindow(i);
+        if (bg != None)
+            bgwins[bgcount++] = bg;
+    }
+
+    if (bgcount == 0) {
+        usleep(2000000);
+    } else {
+        uint32_t prev_px = 0;
+        int have_prev = 0;
+
+        for (int attempt = 0; attempt < 20; attempt++) {
+            /* Drain stale paint events before each clear so waitForPaint
+             * only sees Expose events from the XClearArea calls below. */
+            XEvent drain_ev;
+            while (XCheckMaskEvent(display, ExposureMask | VisibilityChangeMask, &drain_ev))
+                ;
+
+            for (int i = 0; i < bgcount; i++) {
+                XRaiseWindow(display, bgwins[i]);
+                XClearArea(display, bgwins[i], 0, 0, 0, 0, True);
+            }
+            XSync(display, False);
+            waitForPaint(display, bgwins, bgcount, 500);
+
+            XImage *img = XGetImage(display, bgwins[0], 0, 0, 1, 1, AllPlanes, ZPixmap);
+            if (img) {
+                uint32_t px = (uint32_t)XGetPixel(img, 0, 0);
+                XDestroyImage(img);
+                if (have_prev && px == prev_px)
+                    break;  /* framebuffer stable: NVIDIA restore complete */
+                prev_px = px;
+                have_prev = 1;
+            }
+
+            usleep(300000);
+        }
+    }
+
+    /* GPU scanout settle. */
+    usleep(100000);
+
+    for (int i = 0; i < nscreens; i++)
+        XFixesShowCursor(display, RootWindow(display, i));
+
+    XSync(display, False);
+}
+
+/* Called each poll tick: detect resume via CLOCK_BOOTTIME jump, hide the
+ * cursor immediately, and fire the full repaint+show sequence 1500 ms later
+ * once the driver has had time to complete its own display restore. */
+static void pollResumeState(Display *display, struct aModules *modules,
+                            unsigned long *last_time,
+                            unsigned long *deferred_refresh_at) {
+    unsigned long now = alock_mtime();
+
+    if (now - *last_time > 500) {
+        int ns = ScreenCount(display);
+        for (int i = 0; i < ns; i++)
+            XFixesHideCursor(display, RootWindow(display, i));
+        *deferred_refresh_at = now + 1500;
+    }
+    *last_time = now;
+
+    if (*deferred_refresh_at && now >= *deferred_refresh_at) {
+        refreshCursorAfterResume(display, modules);
+        *deferred_refresh_at = 0;
+        *last_time = alock_mtime();
+    }
+}
