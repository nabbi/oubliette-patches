+/* On resume from suspend, hide the cursor via XFixes, repaint all background
+ * windows, wait for the repaint to land, then show the cursor again.
+ * XFixesHideCursor removes the cursor from the rendering pipeline entirely,
+ * so XFixesShowCursor forces the driver to re-read the framebuffer from scratch
+ * rather than reusing any cached sprite backing. The pointer grab is never released. */
+static void refreshCursorAfterResume(Display *display, struct aModules *modules) {
+
+    int nscreens = ScreenCount(display);
+    Window bgwins[nscreens];
+    int bgcount = 0;
+
+    /* Hide cursor on all screens: no transparency compositing during repaint,
+     * and no stale save-under cache to reuse when the cursor reappears. */
+    for (int i = 0; i < nscreens; i++)
+        XFixesHideCursor(display, RootWindow(display, i));
+
+    /* Discard stale paint events so waitForPaint sees only the fresh ones below. */
+    {
+        XEvent drain_ev;
+        while (XCheckMaskEvent(display, ExposureMask | VisibilityChangeMask, &drain_ev))
+            ;
+    }
+
+    for (int i = 0; i < nscreens; i++) {
+        Window bg = modules->background->getwindow(i);
+        if (bg != None) {
+            XRaiseWindow(display, bg);
+            /* XClearArea with exposures=True generates an Expose event for waitForPaint. */
+            XClearArea(display, bg, 0, 0, 0, 0, True);
+            bgwins[bgcount++] = bg;
+        }
+    }
+
+    XSync(display, False);
+
+    if (bgcount > 0) {
+        waitForPaint(display, bgwins, bgcount, 1000);
+        /* GPU fence: XGetImage forces the server to finish rendering all pending
+         * drawing commands to the framebuffer before we restore the cursor. */
+        XImage *img = XGetImage(display, bgwins[0], 0, 0, 1, 1, AllPlanes, ZPixmap);
+        if (img) XDestroyImage(img);
+    } else {
+        usleep(500000);
+    }
+
+    /* Extra settle time for the GPU scanout buffer. */
+    usleep(100000);
+
+    /* Restore cursor: the driver reads the framebuffer fresh at this point. */
+    for (int i = 0; i < nscreens; i++)
+        XFixesShowCursor(display, RootWindow(display, i));
+
+    XSync(display, False);
+}
