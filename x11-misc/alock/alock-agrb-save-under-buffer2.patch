+/* On resume from suspend, swap to a blank cursor, repaint all background
+ * windows, hold for 500 ms to allow the GPU scanout buffer to update, then
+ * restore the ARGB cursor.  The pointer grab is never released. */
+static void refreshCursorAfterResume(Display *display, struct aModules *modules,
+                                     Cursor blank_cursor, Cursor argb_cursor) {
+
+    int nscreens = ScreenCount(display);
+
+    XChangeActivePointerGrab(display, 0, blank_cursor, CurrentTime);
+
+    for (int i = 0; i < nscreens; i++) {
+        Window bg = modules->background->getwindow(i);
+        if (bg != None) {
+            XRaiseWindow(display, bg);
+            XClearWindow(display, bg);
+        }
+    }
+
+    XSync(display, False);
+    usleep(500000);
+
+    XChangeActivePointerGrab(display, 0, argb_cursor, CurrentTime);
+    XSync(display, False);
+}
