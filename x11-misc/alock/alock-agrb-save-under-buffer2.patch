+/*
+ * Poll for Expose/VisibilityNotify events from one of our background
+ * windows, confirming the GPU has actually rendered the content.
+ * Waits up to 500 ms with 10 ms sleep intervals.  Returns true if a
+ * paint event was seen, false on timeout.
+ */
+static bool waitForPaint(Display *display, const Window *bgwins,
+        int bgcount, long mask) {
+
+    unsigned long start = alock_mtime();
+    XEvent ev;
+
+    while (alock_mtime() - start < 500) {
+
+        while (XCheckMaskEvent(display, mask, &ev)) {
+
+            Window src = None;
+            if (ev.type == Expose)
+                src = ev.xexpose.window;
+            else if (ev.type == VisibilityNotify)
+                src = ev.xvisibility.window;
+            else
+                /* Drain non-paint events (e.g. StructureNotify) */
+                continue;
+
+            for (int j = 0; j < bgcount; j++)
+                if (bgwins[j] == src) {
+                    XSync(display, False);
+                    return true;
+                }
+        }
+        usleep(10000);
+    }
+
+    XSync(display, False);
+    return false;
+}
+
+/*
+ * Create a 1x1 fully transparent cursor (invisible).  Used as a safe
+ * placeholder during background repaints — unlike None (which shows the
+ * default arrow) this hides the pointer completely and has no alpha
+ * channel, so there is no save-under issue.
+ */
+static Cursor makeBlankCursor(Display *display) {
+
+    char data = 0;
+    XColor black = { 0 };
+    Pixmap blank = XCreateBitmapFromData(display,
+            DefaultRootWindow(display), &data, 1, 1);
+    Cursor cursor = XCreatePixmapCursor(display,
+            blank, blank, &black, &black, 0, 0);
+    XFreePixmap(display, blank);
+    return cursor;
+}
+
+#if ENABLE_XRENDER
+/*
+ * Software-cursor overlay.
+ *
+ * The X11 cursor sprite path on NVIDIA proprietary unreliably composites
+ * ARGB cursors against stale framebuffer pixels after resume — desktop
+ * content from before suspend bleeds through the cursor's transparent
+ * regions.  Six prior approaches that fought the cursor sprite save-under
+ * (paint-wait, pointer warp, blank-swap, XGetImage fence, ungrab/regrab,
+ * XID recreate) did not reliably defeat the NVIDIA cursor cache.
+ *
+ * This overlay sidesteps the X cursor sprite path entirely:
+ *
+ *   - The actual X11 cursor is a 1x1 invisible blank (no visible alpha).
+ *   - The cursor IMAGE is composited directly onto the lock background
+ *     window via XRenderComposite(PictOpOver), in software, on every
+ *     pointer-motion event.
+ *   - A "scratch" pixmap holds the background pixels currently under
+ *     the cursor, so we can cleanly restore them when the pointer moves.
+ *
+ * Because rendering goes through normal window compositing (not cursor
+ * save-under), there is no path for stale framebuffer content to bleed
+ * through the cursor — the bug class is structurally eliminated and the
+ * cursor retains true ARGB transparency against the lock background.
+ */
+struct swCursor {
+    Display *display;
+    int width, height;
+    int xhot, yhot;
+
+    Pixmap src_pm;          /* ARGB cursor pixels (depth 32) */
+    Picture src_pic;
+
+    Window bgwin;           /* the bg window the cursor is drawn on */
+    Picture bg_pic;
+    Pixmap scratch;         /* saved bg pixels under cursor (same depth as bg) */
+    GC scratch_gc;
+    int scratch_valid;
+    int scratch_x, scratch_y;   /* top-left of cursor image (window-local) */
+
+    int last_root_x, last_root_y;  /* last hot-spot position (root coords) */
+};
+
+static struct swCursor *swCursorCreate(Display *dpy,
+        const struct aCursorImage *img, Window bgwin) {
+
+    if (!img || img->width == 0 || img->height == 0)
+        return NULL;
+
+    Screen *screen = DefaultScreenOfDisplay(dpy);
+    Window root = RootWindowOfScreen(screen);
+
+    XRenderPictFormat *argb_fmt =
+            XRenderFindStandardFormat(dpy, PictStandardARGB32);
+    if (!argb_fmt) {
+        fprintf(stderr, "alock: no ARGB32 XRender format\n");
+        return NULL;
+    }
+
+    XWindowAttributes wa;
+    if (!XGetWindowAttributes(dpy, bgwin, &wa))
+        return NULL;
+    XRenderPictFormat *bg_fmt = XRenderFindVisualFormat(dpy, wa.visual);
+    if (!bg_fmt) {
+        fprintf(stderr, "alock: bg window has no XRender format\n");
+        return NULL;
+    }
+
+    struct swCursor *sc = calloc(1, sizeof(*sc));
+    if (!sc) return NULL;
+
+    sc->display = dpy;
+    sc->width = (int)img->width;
+    sc->height = (int)img->height;
+    sc->xhot = (int)img->xhot;
+    sc->yhot = (int)img->yhot;
+    sc->bgwin = bgwin;
+
+    sc->src_pm = XCreatePixmap(dpy, root, sc->width, sc->height, 32);
+    GC gc = XCreateGC(dpy, sc->src_pm, 0, NULL);
+
+    XImage xim;
+    memset(&xim, 0, sizeof(xim));
+    xim.width = sc->width;
+    xim.height = sc->height;
+    xim.format = ZPixmap;
+    xim.data = (char *)img->pixels;
+    xim.byte_order = alock_native_byte_order();
+    xim.bitmap_unit = 32;
+    xim.bitmap_bit_order = xim.byte_order;
+    xim.bitmap_pad = 32;
+    xim.depth = 32;
+    xim.bits_per_pixel = 32;
+    xim.bytes_per_line = sc->width * 4;
+    xim.red_mask   = 0xff0000;
+    xim.green_mask = 0x00ff00;
+    xim.blue_mask  = 0x0000ff;
+    XInitImage(&xim);
+
+    XPutImage(dpy, sc->src_pm, gc, &xim, 0, 0, 0, 0, sc->width, sc->height);
+    XFreeGC(dpy, gc);
+
+    sc->src_pic = XRenderCreatePicture(dpy, sc->src_pm, argb_fmt, 0, NULL);
+    sc->bg_pic = XRenderCreatePicture(dpy, bgwin, bg_fmt, 0, NULL);
+
+    sc->scratch = XCreatePixmap(dpy, bgwin, sc->width, sc->height, wa.depth);
+    sc->scratch_gc = XCreateGC(dpy, bgwin, 0, NULL);
+    sc->scratch_valid = 0;
+
+    return sc;
+}
+
+/* Stamp the cursor so its hot-spot is at root coords (root_x, root_y).
+ * Restores the previous stamp's background first, saves the new region,
+ * then composites the ARGB cursor over the bg. */
+static void swCursorMove(struct swCursor *sc, int root_x, int root_y) {
+
+    if (!sc) return;
+    Display *dpy = sc->display;
+    int nx = root_x - sc->xhot;
+    int ny = root_y - sc->yhot;
+
+    if (sc->scratch_valid && sc->scratch_x == nx && sc->scratch_y == ny)
+        return;
+
+    if (sc->scratch_valid) {
+        XCopyArea(dpy, sc->scratch, sc->bgwin, sc->scratch_gc,
+                0, 0, sc->width, sc->height,
+                sc->scratch_x, sc->scratch_y);
+    }
+
+    XCopyArea(dpy, sc->bgwin, sc->scratch, sc->scratch_gc,
+            nx, ny, sc->width, sc->height, 0, 0);
+    sc->scratch_valid = 1;
+    sc->scratch_x = nx;
+    sc->scratch_y = ny;
+
+    XRenderComposite(dpy, PictOpOver, sc->src_pic, None, sc->bg_pic,
+            0, 0, 0, 0, nx, ny, sc->width, sc->height);
+
+    sc->last_root_x = root_x;
+    sc->last_root_y = root_y;
+}
+
+/* Drain any further MotionNotify events queued behind `ev` and stamp the
+ * cursor only at the most recent position.  Avoids N redundant restore/
+ * save/composite cycles when motion events arrive in bursts (fast pointer
+ * movement, animation grace period, etc.). */
+static void swCursorMoveCoalesced(struct swCursor *sc, XEvent *ev) {
+    if (!sc) return;
+    int lx = ev->xmotion.x_root;
+    int ly = ev->xmotion.y_root;
+    XEvent more;
+    while (XCheckTypedEvent(sc->display, MotionNotify, &more)) {
+        lx = more.xmotion.x_root;
+        ly = more.xmotion.y_root;
+    }
+    swCursorMove(sc, lx, ly);
+}
+
+/* After the bg window has been repainted (resume, screen-config change),
+ * scratch contains stale content for the wrong bg.  Drop it and re-stamp
+ * the cursor at its current position. */
+static void swCursorRestamp(struct swCursor *sc) {
+    if (!sc) return;
+    sc->scratch_valid = 0;
+    swCursorMove(sc, sc->last_root_x, sc->last_root_y);
+}
+
+static void swCursorDestroy(struct swCursor *sc) {
+    if (!sc) return;
+    Display *dpy = sc->display;
+    if (sc->scratch_valid) {
+        XCopyArea(dpy, sc->scratch, sc->bgwin, sc->scratch_gc,
+                0, 0, sc->width, sc->height,
+                sc->scratch_x, sc->scratch_y);
+    }
+    XFreeGC(dpy, sc->scratch_gc);
+    XFreePixmap(dpy, sc->scratch);
+    XRenderFreePicture(dpy, sc->bg_pic);
+    XRenderFreePicture(dpy, sc->src_pic);
+    XFreePixmap(dpy, sc->src_pm);
+    free(sc);
+}
+#endif /* ENABLE_XRENDER */
+
+/*
+ * Swap grabbed cursor to invisible, repaint backgrounds, wait for the
+ * GPU to finish rendering, then destroy and recreate the real cursor
+ * before installing it.  The new XID forces the X server (including
+ * NVIDIA's cursor compositing) to allocate fresh sprite storage and
+ * capture the save-under from the now-clean framebuffer, rather than
+ * reusing stale cached data from before suspend.
+ *
+ * In sw-cursor-overlay mode the X cursor is permanently a 1x1 blank,
+ * so this function only repaints backgrounds and re-stamps the overlay.
+ */
+static void reinstallCursor(Display *display, Cursor blank,
+        struct aModuleCursor *cursor_module,
+#if ENABLE_XRENDER
+        struct swCursor *sw_cursor,
+#endif
+        const Window *bgwins, int bgcount) {
+
+#if ENABLE_XRENDER
+    if (sw_cursor == NULL)
+#endif
+    {
+        /* Legacy path: hide the X cursor while repainting. */
+        XChangeActivePointerGrab(display, PointerMotionMask,
+                blank, CurrentTime);
+    }
+
+    for (int j = 0; j < bgcount; j++) {
+        XRaiseWindow(display, bgwins[j]);
+        XClearWindow(display, bgwins[j]);
+    }
+    XSync(display, False);
+
+    waitForPaint(display, bgwins, bgcount,
+            ExposureMask | VisibilityChangeMask);
+
+#if ENABLE_XRENDER
+    if (sw_cursor) {
+        /* Bg was wiped — re-stamp the cursor overlay. */
+        swCursorRestamp(sw_cursor);
+        return;
+    }
+#endif
+
+    /* Legacy path: destroy and recreate the X cursor with a fresh XID. */
+    Cursor old = cursor_module->getcursor();
+    if (old != None) {
+        XFreeCursor(display, old);
+        if (cursor_module->m.init(display) != 0) {
+            fprintf(stderr, "alock: warning, cursor reinit failed\n");
+            XChangeActivePointerGrab(display, PointerMotionMask,
+                    blank, CurrentTime);
+            return;
+        }
+    }
+
+    XChangeActivePointerGrab(display, PointerMotionMask,
+            cursor_module->getcursor(), CurrentTime);
+}
